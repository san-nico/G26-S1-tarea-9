  "form": {
    "id": "inscripcion",
    "title": "Inscríbete con nosotros",
    "action": "/submit.php",
    "method": "post",
    "fields": [
      {
        "name": "nombre",
        "label": "Nombre",
        "type": "text",
        "required": true
      },
      {
        "name": "apellido",
        "label": "Apellido",
        "type": "text",
        "required": true
      },
      {
        "name": "rut",
        "label": "RUT",
        "type": "text",
        "placeholder": "12.345.678-9",
        "required": true
      },
      {
        "name": "fecha_nacimiento",
        "label": "Fecha de nacimiento",
        "type": "date",
        "required": true
      },
      {
        "name": "casa_estudios",
        "label": "Casa de estudios",
        "type": "text"
      },
      {
        "name": "carrera",
        "label": "Carrera",
        "type": "text"
      },
      {
        "name": "telefono",
        "label": "Teléfono",
        "type": "tel",
        "placeholder": "+56 9 1234 5678",
        "pattern": "\\+56\\s9\\s\\d{4}\\s\\d{4}"
      },
      {
        "name": "email",
        "label": "Correo Electrónico",
        "type": "email",
        "required": true
      }
    ],
    "submit_label": "Enviar inscripción",
    "csrf": "{{CSRF_TOKEN}}"
  },
